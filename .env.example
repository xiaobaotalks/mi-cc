# mi-cc 配置文件
# 复制此文件为 .env 并填入实际值
# ============================================================
# 默认使用国产大模型（小米 MiMo），兼容 OpenAI 协议通道
# ============================================================

# API Key (必填)
API_KEY=your_api_key_here

# API Base URL (可选，默认小米 MiMo)
BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# 模型名称 (可选，默认 mimo-v2.5-pro)
# 国产模型推荐: mimo-v2.5-pro, mimo-v2.5, mimo-v2-pro, mimo-v2-omni
# OpenAI 兼容: gpt-4o, gpt-4o-mini, gpt-4-turbo
# 其他: claude-3-5-sonnet, glm-4-plus, deepseek-chat, moonshot-v1-128k
MODEL=mimo-v2.5-pro

# 最大 Token 数 (可选，默认按模型自动推断)
#   - MiMo 1M / GPT-4o 128K / Claude 200K / GLM-4 128K / Moonshot 128K / DeepSeek 64K
#   - 未知模型默认 8000
# MAX_TOKEN=8000

# ============================================================
# 可选：多 Provider 故障转移配置
# 当主 Provider 失败时自动切换到备用 Provider
# ============================================================

# 备用 Provider #1 (OpenAI 兼容通道)
# API_KEY_1=sk-openai-xxxx
# BASE_URL_1=https://api.openai.com/v1
# MODEL_1=gpt-4o-mini
# PROVIDER_NAME_1=OpenAI-GPT4

# 备用 Provider #2 (Anthropic Claude)
# API_KEY_2=sk-anthropic-xxxx
# BASE_URL_2=https://api.anthropic.com/v1
# MODEL_2=claude-3-5-sonnet-20241022
# PROVIDER_NAME_2=Claude-3.5

# 备用 Provider #3 (智谱 GLM)
# API_KEY_3=sk-glm-xxxx
# BASE_URL_3=https://open.bigmodel.cn/api/paas/v4/
# MODEL_3=glm-4-plus
# PROVIDER_NAME_3=GLM-4
